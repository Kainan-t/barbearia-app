# =============================================================
#  TEMPLATE DE VARIÁVEIS DE AMBIENTE — BARBEARIA APP
#  Copie este arquivo e preencha com os dados do seu cliente.
#  Na Vercel: Settings → Environment Variables
# =============================================================

# --- Banco de Dados (Neon PostgreSQL) ---
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# --- Autenticação (JWT) ---
# Gere uma chave aleatória forte: openssl rand -base64 32
JWT_SECRET="sua-chave-secreta-aqui"

# --- Identidade da Barbearia ---
NEXT_PUBLIC_NOME="BarberShop"
NEXT_PUBLIC_SLOGAN="Estilo & Precisão em cada corte"
NEXT_PUBLIC_DESCRICAO="Transformamos seu visual com maestria. Agendamento online, atendimento premium e produtos exclusivos."

# --- Contato ---
NEXT_PUBLIC_TELEFONE="(11) 9 9999-9999"
NEXT_PUBLIC_INSTAGRAM="@barbershop"
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/barbershop"

# --- Localização ---
NEXT_PUBLIC_ENDERECO="Rua das Flores, 123 – Centro"
NEXT_PUBLIC_CIDADE="São Paulo – SP"

# --- Horários ---
NEXT_PUBLIC_HORARIO_SEMANA="Seg–Sex: 9h–20h"
NEXT_PUBLIC_HORARIO_SABADO="Sáb: 9h–18h"

# --- SEO ---
NEXT_PUBLIC_SITE_URL="https://seu-projeto.vercel.app"
